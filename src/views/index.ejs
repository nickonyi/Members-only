<!DOCTYPE html>
<html lang="en">
  <%- include('partials/header') %>
  <body>
    <%- include('partials/nav') %>
    <section
      class="bg-white border-neutral-200 px-4 py-16 border-b text-center"
    >
      <h2 class="text-4xl font-extrabold mb-4">
        Welcome to <span class="text-rose-600">Circle Access</span>
      </h2>
      <p class="text-gray-600 text-lg mx-auto max-w-2xl">
        Build circles. Exchange ideas. Connect with the real people behind every
        post — only within your circle.
      </p>
      <div class="flex justify-center mt-8 gap-4 cursor-pointer">
        <% if(!user){%>
        <a href="/auth/signup" class="bg-black text-white px-4 py-2 rounded-md"
          >Create Account</a
        >
        <a
          href="/auth/login"
          class="px-4 py-2 bg-gray-100 rounded-md hover:bg-gray-200"
          >Log in</a
        >
        <%} else { %>
           <a href="/posts"
            class="bg-black text-white px-4 py-2 rounded-md">
            Browse Posts
           </a>
           <a href="/circles"
              class="px-4 py-2 bg-gray-100 rounded-md hover:bg-gray-200">
              Explore Circles
           </a>
          <%}%>
      </div>
    </section>

    <section class="bg-gray-50 border-neutral-200 border-t border-b py-14">
         <div class="wrapper">

           <h2 class="text-2xl font-bold mb-6">Popular Circles</h2>

           <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
             <% circles.forEach(circle => { %>
               <% include ('partials/circleCard'), { circle: circle } %>
             <% }) %>
           </div>
         </div>
    </section>
  </body>
  <script src="/js/main.js"></script>
</html>
