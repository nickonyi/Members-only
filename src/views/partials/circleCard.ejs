<div class="bg-white p-5 border border-neutral-200 rounded-md shadow-sm hover:shadow-md transition">
    <h3 class="font-semibold text-lg">
        <%= circle.name %>
    </h3>
    <p class="text-gray-600 text-sm mt-2">
        <%= circle.description %>
    </p>

    <div class="flex justify-between items-center mt-4 text-sm text-gray-500">
        <span>Total Members: <%= circle.membersCount %></span>
        <% if (!hideOwner) { %>
            <span>Owner: <%= circle.ownerUsername %></span>
        <% } %>
    </div>

    <a href="/circles/<%= circle.id %>"
       class="mt-4 text-sm inline-block text-rose-600 hover:underline">
        View Circle →
    </a>
</div>