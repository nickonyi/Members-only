<%- include('partials/header') %> <%- include('partials/nav') %>
<section class="py-10">
  <div class="flex items-center flex-col justify-center">
    <div class="max-w-xs pt-6">
      <h1 class="text-2xl font-semibold">Welcome to Circle Access</h1>
      <p class="text-xs text-gray-500 mt-2">
        Create an account to start exploring circles and connecting.
      </p>

      <form action="/auth/signup" method="POST" class="flex flex-col gap-2">
        <label for="firstName">
          First Name:
          <input
            type="text"
            name="firstName"
            id="firstName"
            class="border p-2 w-full rounded"
            value="<%= formData.firstName || '' %>"
          />
          <% if (errors.firstName) { %>
            <p class="text-red-500 text-xs italic"><%= errors.firstName %></p>
          <% } %>
        </label>
        <label for="lastName">
          Last Name:
          <input
            type="text"
            name="lastName"
            id="lastName"
            class="border p-2 w-full rounded"
            value="<%= formData.lastName || '' %>"
          />
          <% if (errors.lastName) { %>
            <p class="text-red-500 text-xs italic"><%= errors.lastName %></p>
          <% } %>
        </label>
        <label for="email">
          email:
          <input
            type="text"
            name="email"
            id="email"
            class="border p-2 w-full rounded"
            value="<%= formData.email || '' %>"
          />
          <% if (errors.email) { %>
            <p class="text-red-500 text-xs italic"><%= errors.email %></p>
          <% } %>
        </label>
        <label for="password">
          Password:
          <input
            type="password"
            name="password"
            id="password"
            class="border p-2 w-full rounded"
          />
          <% if (errors.password) { %>
            <p class="text-red-500 text-xs italic"><%= errors.password %></p>
          <% } %>
        </label>
        <label for="confirmPassword">
          Confirm Password:
          <input
            type="password"
            name="confirmPassword"
            id="confirmPassword"
            class="border p-2 w-full rounded"
          />
          <% if (errors.confirmPassword) { %>
            <p class="text-red-500 text-xs italic"><%= errors.confirmPassword %></p>
          <% } %>
        </label>
        <button
          type="submit"
          class="border-2 bg-neutral-950 text-white px-3 rounded-lg cursor-pointer text-sm py-2"
        >
          Sign Up
        </button>
      </form>
    </div>
    <p class="text-neutral-600 text-sm py-6">
      Already Part of Circle Access?
      <a href="/auth/login" class="text-black font-semibold">Login instead</a>
    </p>
  </div>
</section>
